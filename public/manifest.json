{
  "manifest_version": 3,
  "name": "FocusTrack Productivity Manager",
  "version": "1.0",
  "description": "Track website usage, block distracting sites, and improve productivity.",
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "FocusTrack"
  },
  "background": {
    "service_worker": "background.js"
  }
}